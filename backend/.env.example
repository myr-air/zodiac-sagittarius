DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/sagittarius
SAGITTARIUS_BIND_ADDR=127.0.0.1:5181
PASSKEY_ALLOWED_ORIGINS=localhost,127.0.0.1,0.0.0.0
EMAIL_DELIVERY=log
# Set EMAIL_DELIVERY=smtp for Brevo or another SMTP relay.
# Set EMAIL_DELIVERY=sendmail to shell out to a local sendmail-compatible command.
# Set EMAIL_DELIVERY=off only for integration runs where you want delivery disabled.
EMAIL_FROM="Sagittarius <noreply@sagittarius.local>"
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
