# Copy to backend/.env for local API runs (`make backend-dev` / cargo).
# Loaded automatically when `backend/.env` exists.

DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/sagittarius
SAGITTARIUS_BIND_ADDR=127.0.0.1:5181
SAGITTARIUS_ENV=development
SAGITTARIUS_SEED_SAMPLE_DATA=1
PASSKEY_ALLOWED_ORIGINS=localhost,127.0.0.1
RUST_LOG=info,tower_http=info,sagittarius_api=info

# Email: log | smtp | sendmail | off
EMAIL_DELIVERY=log
EMAIL_FROM="Joii <noreply@joii.local>"
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SENDMAIL_COMMAND=sendmail

# Optional: place resolution / AI import / day-plan-assist
# PLACE_RESOLUTION_ENABLED=0
# PLACE_RESOLUTION_USER_AGENT=Joii local place resolver
# SAGITTARIUS_AI_PROVIDER=rules
# OPENROUTER_API_KEY=
# Model preference is optional for now (defaults to openrouter/free). Account
# settings will own this later. Temporary server overrides:
# OPENROUTER_MODEL=openai/gpt-5.2
# OPENROUTER_MODELS=openrouter/free
# OPENROUTER_SITE_URL=http://127.0.0.1:5180
# OPENROUTER_SITE_NAME=Joii
