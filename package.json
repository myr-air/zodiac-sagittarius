{
  "name": "sagittarius-travel-cockpit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 5180",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 5180",
    "lint": "eslint .",
    "storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006",
    "build-storybook": "STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "typescript": "6.0.3"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/nextjs-vite": "10.4.1",
    "@tailwindcss/postcss": "4.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "29.1.1",
    "postcss": "8.5.15",
    "tailwindcss": "4.2.4",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.1.7"
  }
}
