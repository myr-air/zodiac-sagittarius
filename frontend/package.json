{
  "name": "joii",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "NODE_OPTIONS=--no-warnings next dev --hostname 127.0.0.1 --port 5180",
    "build": "NODE_OPTIONS=--no-warnings next build",
    "start": "NODE_OPTIONS=--no-warnings next start --hostname ${HOSTNAME:-127.0.0.1} --port ${PORT:-5180}",
    "lint": "eslint .",
    "typecheck": "NODE_OPTIONS=--no-warnings next typegen && tsc --noEmit",
    "test": "NODE_OPTIONS=--no-warnings vitest run",
    "verify:frontend": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4.3.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
